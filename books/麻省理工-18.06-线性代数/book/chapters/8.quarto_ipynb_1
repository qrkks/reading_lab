        "# Ax = b 可解性及解的结构"
      ],
      "id": "eec490b0"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import sympy as sp\n",
        "from IPython.display import display, Math\n",
        "\n",
        "A = sp.Matrix([\n",
        "    [1, 2, 2, 2],\n",
        "    [2, 4, 6, 8],\n",
        "    [3, 6, 8, 10],\n",
        "])\n",
        "display(A)\n",
        "\n",
        "col_basis = A.columnspace()\n",
        "# 水平拼接：每一列对应一个基向量\n",
        "col_basis_matrix = sp.Matrix.hstack(*col_basis)\n",
        "\n",
        "print(\"列空间基矩阵（每一列是一个基向量）：\")\n",
        "print(\"col_basis: \")\n",
        "display(col_basis)\n",
        "print(\"col_basis_matrix: \")\n",
        "display(col_basis_matrix)\n",
        "print(\"*col_basis\")\n",
        "display(*col_basis)\n",
        "print(\"列空间维数（秩）：\", col_basis_matrix.rank())"
      ],
      "id": "77885c3a",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "[sympy 能解非齐次方程吗？](../appendices/8.md#sympy-能解非齐次方程吗)\n",
        "\n",
        "[如果要方程组有解，b\n",
        "需要符合什么条件？](../appendices/8.md#如果要方程组有解b-需要符合什么条件)"
      ],
      "id": "042eb9b3"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import sympy as sp\n",
        "from IPython.display import display, Latex, Markdown\n",
        "\n",
        "b1, b2, b3 = sp.symbols(\"b1,b2,b3\")\n",
        "\n",
        "A = sp.Matrix([\n",
        "    [1, 2, 2, 2, b1],\n",
        "    [2, 4, 6, 8, b2],\n",
        "    [3, 6, 8, 10, b3],\n",
        "])\n",
        "U = A.echelon_form()\n",
        "display(A)\n",
        "print(\"echelon form: \")\n",
        "display(U)\n",
        "display(U[-1, -1])\n",
        "display(Markdown(f\"方程组有没有解由 $U_{{-1,-1}}={sp.latex(U[-1, -1])}$ 决定。\"))\n",
        "print(\"RREF: \")\n",
        "display(\"A.rref(): \", A.rref())\n",
        "display(\"*A.rref(): \", *A.rref())"
      ],
      "id": "743e68f3",
      "execution_count": null,
      "outputs": []
    },
